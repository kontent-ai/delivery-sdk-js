{
	"name": "@kontent-ai/delivery-sdk",
	"version": "17.0.0-preview.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/kontent-ai/delivery-sdk-js"
	},
	"private": false,
	"author": "richard sustek",
	"license": "MIT",
	"description": "Official Kontent.AI Delivery API SDK",
	"keywords": [
		"Kontent",
		"Kontent.ai",
		"Kontent SDK",
		"Kontent API",
		"Kontent Delivery",
		"Kontent Javascript",
		"Kontent Node.js",
		"Kontent Typescript"
	],
	"engines": {
		"node": ">= 22"
	},
	"exports": "./dist/public_api.js",
	"types": "./dist/public_api.d.ts",
	"type": "module",
	"scripts": {
		"prepublishOnly": "npm run build",
		"eslint": "eslint -c eslint.config.mjs .",
		"lint": "npm run biome:check && npm run eslint",
		"build": "npm run lint && npm run build:noemit && npm run clean && tsc --p tsconfig.build.json && npm run update:version",
		"build:noemit": "tsc --p tsconfig.json",
		"test": "npm run test:unit && npm run test:integration && npm run test:types",
		"test:unit": "vitest run --config=vitest-unit.config.ts",
		"test:integration": "vitest run --config=vitest-integration.config.ts",
		"test:types": "tsc --p tests/types/tsconfig.json",
		"biome:check": "biome check",
		"biome:fix": "biome check --write",
		"biome:fix:unsafe": "biome check --write --unsafe",
		"clean": "tsx scripts/clean.ts",
		"update:version": "tsx ./scripts/update-version.ts"
	},
	"peerDependencies": {
		"@kontent-ai/core-sdk": "^12.0.0-preview.20",
		"zod": "^4"
	},
	"devDependencies": {
		"@kontent-ai/biome-config": "0.7.0",
		"@kontent-ai/eslint-config": "2.4.1",
		"eslint": "10.1.0",
		"@biomejs/biome": "2.4.9",
		"@types/node": "25.5.0",
		"typescript": "6.0.2",
		"vitest": "4.1.2",
		"tsx": "4.21.0"
	}
}
