{
	"name": "@kontent-ai/delivery-sdk",
	"version": "17.0.0-preview.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/kontent-ai/delivery-sdk-js"
	},
	"private": false,
	"author": "richard sustek",
	"license": "MIT",
	"description": "Official Kontent.AI Delivery API SDK",
	"keywords": [
		"Kontent",
		"Kontent.ai",
		"Kontent SDK",
		"Kontent API",
		"Kontent Delivery",
		"Kontent Javascript",
		"Kontent Node.js",
		"Kontent Typescript"
	],
	"engines": {
		"node": ">= 22"
	},
	"exports": {
		".": {
			"types": "./dist/public_api.d.ts",
			"default": "./dist/public_api.js"
		},
		"./schemas": {
			"types": "./dist/public_schemas.d.ts",
			"default": "./dist/public_schemas.js"
		}
	},
	"types": "./dist/public_api.d.ts",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"prepublishOnly": "pnpm run build",
		"eslint": "eslint -c eslint.config.mjs .",
		"lint": "pnpm run biome:check && pnpm run eslint",
		"build": "pnpm run lint && pnpm run clean && pnpm run build:ts && pnpm run update:version",
		"build:ts": "tsgo -p tsconfig.build.json",
		"test": "vitest run --config=vitest.config.ts --coverage",
		"test:unit": "vitest run --config=vitest-unit.config.ts",
		"test:integration": "vitest run --config=vitest-integration.config.ts",
		"test:types": "tsgo -p sample/tsconfig.json",
		"biome:check": "biome check",
		"biome:fix": "biome check --write",
		"biome:fix:unsafe": "biome check --write --unsafe",
		"clean": "tsx scripts/clean.ts",
		"update:version": "tsx ./scripts/update-version.ts",
		"bundle:size": "tsx scripts/measure-bundle.ts",
		"bundle:create": "tsx scripts/create-bundles.ts"
	},
	"peerDependencies": {
		"@kontent-ai/core-sdk": "^12.0.0-preview.40",
		"ts-pattern": "^5",
		"zod": "^4"
	},
	"devDependencies": {
		"@kontent-ai/biome-config": "0.7.0",
		"@kontent-ai/eslint-config": "2.4.1",
		"eslint": "10.5.0",
		"@biomejs/biome": "2.4.16",
		"@types/node": "25.9.3",
		"vitest": "4.1.9",
		"@vitest/coverage-v8": "4.1.8",
		"tsx": "4.22.4",
		"@typescript/native-preview": "7.0.0-dev.20260614.1",
		"esbuild": "0.28.1"
	}
}
